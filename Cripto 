      "cell_type": "code",
      "source": [
        "!pip install requests pandas ta gradio plotly -q\n",
        "\n",
        "import requests\n",
        "import pandas as pd\n",
        "import ta\n",
        "import gradio as gr\n",
        "import plotly.graph_objects as go\n",
        "import time\n",
        "\n",
        "# ===== MEMÓRIA =====\n",
        "ultimo_resultado = {}\n",
        "\n",
        "# ===== MOEDAS =====\n",
        "coins = {\n",
        "    \"Bitcoin\": \"bitcoin\",\n",
        "    \"Ethereum\": \"ethereum\",\n",
        "    \"Solana\": \"solana\",\n",
        "    \"BNB\": \"binancecoin\",\n",
        "    \"XRP\": \"ripple\",\n",
        "    \"Dogecoin\": \"dogecoin\"\n",
        "}\n",
        "\n",
        "# ===== FUNÇÃO ESTÁVEL (ANTI ERRO) =====\n",
        "def pegar_dados(coin_id):\n",
        "    url = f\"https://api.coingecko.com/api/v3/coins/{coin_id}/market_chart\"\n",
        "    params = {\"vs_currency\": \"usd\", \"days\": \"1\"}\n",
        "\n",
        "    for tentativa in range(3):\n",
        "        try:\n",
        "            response = requests.get(url, params=params, timeout=10)\n",
        "\n",
        "            if response.status_code == 200:\n",
        "                data = response.json()\n",
        "                prices = [p[1] for p in data[\"prices\"]]\n",
        "\n",
        "                df = pd.DataFrame(prices, columns=[\"price\"])\n",
        "                return df\n",
        "\n",
        "            elif response.status_code == 429:\n",
        "                time.sleep(5)  # espera se bloqueado\n",
        "\n",
        "            else:\n",
        "                time.sleep(2)\n",
        "\n",
        "        except:\n",
        "            time.sleep(2)\n",
        "\n",
        "    return None\n",
        "\n",
        "# ===== ANÁLISE =====\n",
        "def analisar(nome_moeda):\n",
        "    global ultimo_resultado\n",
        "\n",
        "    time.sleep(2)  # evita bloqueio\n",
        "\n",
        "    coin_id = coins[nome_moeda]\n",
        "    df = pegar_dados(coin_id)\n",
        "\n",
        "    if df is None or len(df) < 50:\n",
        "        return \"⚠️ Erro ao buscar dados. Tente novamente.\", None\n",
        "\n",
        "    # indicadores\n",
        "    df[\"rsi\"] = ta.momentum.RSIIndicator(df[\"price\"]).rsi()\n",
        "    df[\"ma\"] = df[\"price\"].rolling(20).mean()\n",
        "    df[\"ma50\"] = df[\"price\"].rolling(50).mean()\n",
        "\n",
        "    price = df[\"price\"].iloc[-1]\n",
        "    rsi = df[\"rsi\"].iloc[-1]\n",
        "    ma = df[\"ma\"].iloc[-1]\n",
        "    ma50 = df[\"ma50\"].iloc[-1]\n",
        "\n",
        "    # ===== SCORE =====\n",
        "    score = 0\n",
        "\n",
        "    if rsi < 30:\n",
        "        score += 3\n",
        "    elif rsi > 70:\n",
        "        score -= 3\n",
        "\n",
        "    if price > ma:\n",
        "        score += 2\n",
        "    else:\n",
        "        score -= 2\n",
        "\n",
        "    if price > ma50:\n",
        "        score += 2\n",
        "    else:\n",
        "        score -= 2\n",
        "\n",
        "    # ===== DECISÃO =====\n",
        "    if score >= 4:\n",
        "        decisao = \"🟢 COMPRAR AGORA\"\n",
        "        mensagem = \"Forte tendência de ALTA nas próximas horas\"\n",
        "        tempo = \"2 a 6 horas\"\n",
        "    elif score >= 2:\n",
        "        decisao = \"🟢 POSSÍVEL COMPRA\"\n",
        "        mensagem = \"Boa chance de subida, entrada razoável\"\n",
        "        tempo = \"2 a 4 horas\"\n",
        "    elif score <= -4:\n",
        "        decisao = \"🔴 NÃO ENTRAR\"\n",
        "        mensagem = \"Forte risco de queda nas próximas horas\"\n",
        "        tempo = \"curto prazo\"\n",
        "    elif score <= -2:\n",
        "        decisao = \"🔴 EVITAR\"\n",
        "        mensagem = \"Tendência de queda, risco alto\"\n",
        "        tempo = \"1 a 3 horas\"\n",
        "    else:\n",
        "        decisao = \"🟡 ESPERAR\"\n",
        "        mensagem = \"Mercado lateral, sem tendência clara\"\n",
        "        tempo = \"-\"\n",
        "\n",
        "    # ===== ESTABILIDADE =====\n",
        "    anterior = ultimo_resultado.get(nome_moeda)\n",
        "\n",
        "    if anterior:\n",
        "        if abs(anterior[\"score\"] - score) < 2:\n",
        "            decisao = anterior[\"decisao\"]\n",
        "            mensagem = anterior[\"mensagem\"]\n",
        "            tempo = anterior[\"tempo\"]\n",
        "\n",
        "    ultimo_resultado[nome_moeda] = {\n",
        "        \"score\": score,\n",
        "        \"decisao\": decisao,\n",
        "        \"mensagem\": mensagem,\n",
        "        \"tempo\": tempo\n",
        "    }\n",
        "\n",
        "    # ===== CONFIANÇA =====\n",
        "    confianca = min(90, 55 + abs(score) * 7)\n",
        "\n",
        "    # ===== RESULTADO =====\n",
        "    resultado = f\"\"\"\n",
        "# 💰 {nome_moeda}\n",
        "\n",
        "## {decisao}\n",
        "\n",
        "👉 {mensagem}\n",
        "\n",
        "⏱️ Tempo estimado: {tempo}\n",
        "📊 Confiança: {confianca}%\n",
        "\n",
        "💵 Preço atual: ${price:.2f}\n",
        "📈 RSI: {rsi:.1f}\n",
        "\n",
        "⚠️ Não é recomendação financeira\n",
        "\"\"\"\n",
        "\n",
        "    # ===== GRÁFICO =====\n",
        "    fig = go.Figure()\n",
        "    fig.add_trace(go.Scatter(y=df[\"price\"], mode='lines'))\n",
        "    fig.update_layout(\n",
        "        template=\"plotly_dark\",\n",
        "        height=320,\n",
        "        margin=dict(l=10, r=10, t=30, b=10)\n",
        "    )\n",
        "\n",
        "    return resultado, fig\n",
        "\n",
        "\n",
        "# ===== INTERFACE =====\n",
        "with gr.Blocks(\n",
        "    css=\"\"\"\n",
        "    body {background:#0b0b0b;}\n",
        "    button {\n",
        "        background:linear-gradient(90deg,#ff0000,#ff4d4d);\n",
        "        color:white;\n",
        "        border-radius:10px;\n",
        "        font-size:16px;\n",
        "        font-weight:bold;\n",
        "    }\n",
        "    \"\"\"\n",
        ") as app:\n",
        "\n",
        "    gr.Markdown(\"# 🚀 Crypto Analyzer PRO (Estável)\")\n",
        "\n",
        "    moeda = gr.Radio(\n",
        "        choices=list(coins.keys()),\n",
        "        value=\"Bitcoin\",\n",
        "        label=\"Escolha a moeda\"\n",
        "    )\n",
        "\n",
        "    btn = gr.Button(\"🔍 ANALISAR MERCADO\")\n",
        "\n",
        "    texto = gr.Markdown()\n",
        "    grafico = gr.Plot()\n",
        "\n",
        "    btn.click(analisar, inputs=moeda, outputs=[texto, grafico])\n",
        "\n",
        "app.launch()"
      ],
